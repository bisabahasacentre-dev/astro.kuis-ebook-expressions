---
// Bagian Frontmatter Astro
const title = "Interactive Audio Lesson - BBC Pare";
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="container">
    <div class="quiz-banner">
        <img 
            src="/Images/Banner-kuis-web.webp" 
            alt="1000 Common English Expressions"
            loading="lazy"
        />
    </div>

    <div class="header-player">
        <h2>Unit 2 : at The Restaurant</h2>
        <p style="font-size: 0.75rem; color: #64748b; margin-top: -10px; margin-bottom: 15px;">
            Putar audio dan baca text dialognya lalu ikuti cara pelafalannya!
        </p>
        <audio id="mainAudio" controls preload="metadata">
            <source src="audio/Audio_at_the_restaurant.MP3" type="audio/mpeg">
        </audio>

        <div class="speed-wrapper">
            <button class="btn-speed" onclick="setPlaySpeed(0.5, this)">0.5x</button>
            <button class="btn-speed" onclick="setPlaySpeed(0.8, this)">0.8x</button>
            <button class="btn-speed active" onclick="setPlaySpeed(1.0, this)">Normal</button>
            <button class="btn-speed" onclick="setPlaySpeed(1.2, this)">1.2x</button>
        </div>
    </div>

    <div class="transcript-container" id="transcriptBody">
        <div class="dialog-card" data-time="0">
            <span class="speaker">Rian</span>
            <span class="message">This place looks busy! Sorry, a table for two, please!</span>
        </div>

        <div class="dialog-card" data-time="6">
            <span class="speaker">Waiter</span>
            <span class="message">Right this way, Sir.</span>
        </div>

        <div class="dialog-card" data-time="9">
            <span class="speaker">Mark</span>
            <span class="message">Nice, It's perfect. Thanks! Can I get the menu?</span>
        </div>
        
        <div class="dialog-card" data-time="14">
            <span class="speaker">Waiter</span>
            <span class="message">Here you go. What would you like to order?</span>
        </div>

        <div class="dialog-card" data-time="17">
            <span class="speaker">Mark</span>
            <span class="message">Well, everything looks delicious. What do you recommend?</span>
        </div>

        <div class="dialog-card" data-time="22">
            <span class="speaker">Waiter</span>
            <span class="message">Our Chef's Special Creamy Pasta is very popular today.</span>
        </div>

        <div class="dialog-card" data-time="27">
            <span class="speaker">Mark</span>
            <span class="message">Sounds good! alright, I’d like to have that and make it dine in, please.</span>
        </div>

        <div class="dialog-card" data-time="33">
            <span class="speaker">Rian</span>
            <span class="message">I'll go with the Grilled Chicken. And could I have some water?</span>
        </div>

        <div class="dialog-card" data-time="38">
            <span class="speaker">Waiter</span>
            <span class="message"> Noted. Anything else?</span>
        </div>

        <div class="dialog-card" data-time="41">
            <span class="speaker">Rian</span>
            <span class="message">Actually, I want one Pepperoni Pizza To go, please (US) for my brother.</span>
        </div>

        <div class="dialog-card" data-time="46">
            <span class="speaker">Mark</span>
            <span class="message">And a Blueberry Muffin, Take away, please (UK) for me.</span>
        </div>

        <div class="dialog-card" data-time="51">
            <span class="speaker">Waiter</span>
            <span class="message">Coming right up!</span>
        </div>

        <div class="dialog-card" data-time="53">
            <span class="speaker">Mark</span>
            <span class="message">Oh, wow! This pasta is amazing. It's savoury and the taste is very rich.</span>
        </div>

        <div class="dialog-card" data-time="61">
            <span class="speaker">Rian</span>
            <span class="message">Really? My chicken is a bit disappointing... it's tasteless. No salt at all.</span>
        </div>

        <div class="dialog-card" data-time="68">
            <span class="speaker">Mark</span>
            <span class="message">That's too bad. Try this lemon sauce then, but be careful, it's sour!</span>
        </div>

        <div class="dialog-card" data-time="76">
            <span class="speaker">Rian</span>
            <span class="message">Looks interesting. May I have some?</span>
        </div>

        <div class="dialog-card" data-time="80">
            <span class="speaker">Mark</span>
            <span class="message">That was filling. Can I get the bill?</span>
        </div>

        <div class="dialog-card" data-time="85">
            <span class="speaker">Rian</span>
            <span class="message">Wait, who's gonna pay for this? Is it your birthday?</span>
        </div>
        
        <div class="dialog-card" data-time="89">
            <span class="speaker">Mark</span>
            <span class="message">Haha, no! But it's on me since I just got my bonus today.</span>
        </div>

        <div class="dialog-card" data-time="94">
            <span class="speaker">Rian</span>
            <span class="message">Are you sure? Let's split the bill if you want.</span>
        </div>

        <div class="dialog-card" data-time="97">
            <span class="speaker">Waiter</span>
            <span class="message">No worries, Rian! (To the waiter) Here's the money. Keep the change!</span>
        </div>
    </div>
</div>

<style is:global>
    /* Reset & Base Styling */
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

    :root {
        --primary: #4f46e5;
        --bg-body: #f8fafc;
        --bg-card: #ffffff;
        --text-main: #1e293b;
        --text-grey: #64748b;
        --border: #e2e8f0;
        --active-light: #eef2ff;
    }

    body {
        font-family: 'Inter', sans-serif;
        background-color: var(--bg-body);
        margin: 0;
        padding: 0;
        display: flex;
        justify-content: center;
    }

    /* FIX BANNER: Pastikan tampilan utuh tanpa crop di pojok (tempat logo BBC) */
    .quiz-banner {
        width: 100%;
        margin-bottom: 25px; 
        line-height: 0; /* Menghapus whitespace di bawah image */
        overflow: hidden;
        border-radius: 24px 24px 0 0;
    }

    .quiz-banner img {
        width: 100%;
        height: auto;
        display: block;
        object-fit: contain; /* Memastikan seluruh gambar masuk ke area container */
    }

    /* Container */
    .container {
        width: 100%;
        max-width: 700px;
        background: var(--bg-card);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    /* Sticky Header */
    .header-player {
        position: sticky;
        top: 0;
        background: var(--bg-card);
        padding: 0 20px 20px 20px;
        border-bottom: 1px solid var(--border);
        z-index: 100;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    h2 { margin: 0 0 15px 0; font-size: 1.1rem; font-weight: 700; color: var(--primary); }
    audio { width: 100%; height: 44px; margin-bottom: 15px; }

    /* Speed Control & Transcript (Tidak Ada Perubahan Desain) */
    .speed-wrapper { display: flex; align-items: center; justify-content: space-between; gap: 8px; background: #f8fafc; padding: 6px; border-radius: 12px; }
    .btn-speed { flex: 1; background: transparent; border: none; padding: 8px 5px; border-radius: 8px; cursor: pointer; font-size: 0.75rem; font-weight: 600; color: var(--text-grey); transition: 0.2s; }
    .btn-speed.active { background: var(--primary); color: white; }
    .transcript-container { flex: 1; padding: 15px; overflow-y: auto; scroll-behavior: smooth; }
    .dialog-card { background: #ffffff; border: 1px solid var(--border); padding: 16px; border-radius: 14px; margin-bottom: 12px; cursor: pointer; transition: all 0.3s ease; }
    .dialog-card.active { background-color: var(--active-light); border-color: var(--primary); transform: scale(0.98); }
    .speaker { display: block; font-size: 0.7rem; font-weight: 700; color: var(--text-grey); text-transform: uppercase; margin-bottom: 6px; }
    .message { font-size: 1rem; line-height: 1.5; color: var(--text-main); }

    @media (min-width: 768px) {
        body { padding: 40px 20px; }
        .container { min-height: auto; height: 85vh; border-radius: 24px; border: 1px solid var(--border); box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); }
    }

    /* Penyesuaian khusus mobile agar tidak ada cropping sama sekali */
    @media (max-width: 480px) {
        .quiz-banner { border-radius: 20px 20px 0 0; }
    }
</style>

<script is:inline>
  function playAudio(url) {
    let cleanPath = url.replace('public/', '/');
    if (!cleanPath.startsWith('/')) cleanPath = '/' + cleanPath;

    const audio = new Audio(cleanPath);
    
    console.log("Mencoba memutar:", cleanPath);

    audio.play().then(() => {
        // Jika berhasil, tidak muncul apa-apa
    }).catch(err => {
        // INI AKAN MEMBERITAHU KITA MASALAHNYA
        if (err.name === 'NotAllowedError') {
            alert("Error: Browser memblokir suara. Klik layar dulu baru klik teks.");
        } else if (err.name === 'NotSupportedError' || err.message.includes('supported')) {
            alert("Error: Format file MP3 tidak didukung oleh HP ini.");
        } else {
            alert("Error 404: File tidak ditemukan di " + cleanPath + ". Periksa nama file & folder!");
        }
    });
  }
</script>

</body>
</html>