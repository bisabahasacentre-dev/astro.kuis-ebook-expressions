---
// Bagian Frontmatter Astro
const title = "BBC Ultra Quiz - English Expressions";
---

<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js" is:inline></script>
</head>
<body>

<div id="bbc-quiz-ultra">
    <div class="quiz-banner">
        <img 
            src="/Images/Banner-kuis-web.webp" 
            alt="English Learning Banner"
            loading="lazy"
            width="500"
            height="180"
        />
    </div>

    <div id="quiz-timer-container" style="display: none;">
        <div class="timer-pill">
            <span class="timer-icon">⏱️</span>
            <span id="timer-display">05:00</span>
        </div>
    </div>

    <div id="quiz-loader" style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 200px;">
        <div class="spinner"></div>
        <p style="margin-top: 15px; color: #94a3b8; font-size: 14px; font-weight: 500;">Let's get ready...</p>
    </div>

    <div id="quiz-welcome" style="display: none; text-align: center;">
        <h1 style="color: #007bff; font-size: 1.5rem; font-weight: 800; margin-bottom: 5px;">Quiz Time!</h1>
        <h1 style="color: #007bff; font-size: 1.5rem; font-weight: 600; margin-bottom: 20px; margin-top: 0;">Health and Feeling Unwell</h1>
        
        <div class="instruction-box">
            <h3 style="font-size: 14px; color: #1e293b; margin-bottom: 12px; font-weight: 700; text-align: left; display: flex; align-items: center; gap: 8px;">
                <span>📋</span> Instruksi:
            </h3>
            <ul style="text-align: left; font-size: 13px; color: #475569; padding-left: 18px; line-height: 1.7; margin: 0; list-style-type: disc;">
                <li>Total <strong>15 Soal</strong> (Pilihan Ganda, Isian & Listening).</li>
                <li>Waktu maksimal <strong>5 Menit</strong>.</li>
                <li>Gunakan Earphone untuk soal Listening.</li>
                <li>Skor muncul otomatis di akhir kuis.</li>
            </ul>
        </div>
        
        <button id="start-btn" class="btn-start">Mulai Kuis Sekarang</button>
    </div>

    <div id="quiz-main-content" style="display: none;">
        <div class="q-header">
            <div class="q-progress-bg">
                <div id="q-progress-bar"></div>
            </div>
            <div id="q-status">Memuat soal...</div>
        </div>

        <div id="q-body-area">
            <div id="q-content"></div>
            <div id="q-feedback"></div>
        </div>

        <div id="q-timeout" style="display: none; text-align: center;">
            <div style="font-size: 50px; margin-bottom: 10px;">⏰</div>
            <h2 style="color: #ef4444; margin: 0; font-weight: 800;">Waktu Habis!</h2>
            <button onclick="window.location.reload()" class="btn-retry" style="background: #ef4444;">Ulangi Kuis</button>
        </div>

        <div id="q-result" style="display: none; text-align: center;">
            <h2 id="result-title" style="color: #007bff; margin: 0; font-weight: 800;">Quiz Completed!</h2>
            <div class="final-score">
                <span id="score-num">0</span><small style="font-size: 20px; color: #94a3b8;">/15</small>
            </div>
            <p id="feedback-summary" style="color: #64748b; font-weight: 600; font-size: 1.1rem; margin-bottom: 20px;"></p>
            <button onclick="window.location.reload()" class="btn-retry">Ulangi Kuis</button>
        </div>
    </div>

    <audio id="snd-correct" preload="auto" src="https://assets.mixkit.co/active_storage/sfx/2000/2000-preview.mp3"></audio>
    <audio id="snd-wrong" preload="auto" src="https://assets.mixkit.co/active_storage/sfx/2003/2003-preview.mp3"></audio>
    <audio id="snd-perfect" preload="auto" src="https://assets.mixkit.co/active_storage/sfx/1435/1435-preview.mp3"></audio>
</div>

<style is:global>
    body { background-color: #f8fafc; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; font-family: 'Inter', sans-serif; }
    #bbc-quiz-ultra { max-width: 500px; width: 100%; margin: 40px 20px; background: #ffffff; border-radius: 24px; padding: 40px; box-shadow: 0 10px 40px rgba(0,0,0,0.05); border: 1px solid #f1f5f9; min-height: 420px; box-sizing: border-box; position: relative; overflow: hidden; }
    #quiz-timer-container { display: none; justify-content: center; margin-bottom: 20px; margin-top: -5px; }
    .timer-pill { background: #f8fafc; padding: 8px 18px; border-radius: 50px; border: 1px solid #e2e8f0; display: flex; align-items: center; gap: 8px; font-weight: 800; font-size: 14px; color: #1e293b; }
    .timer-low { color: #ef4444; border-color: #fecaca; background: #fef2f2; animation: blink 1s infinite; }
    @keyframes blink { 50% { opacity: 0.7; } }
    .quiz-banner { margin: -40px -40px 30px -40px; width: calc(100% + 80px); height: 180px; overflow: hidden; }
    .quiz-banner img { width: 100%; height: 100%; object-fit: cover; display: block; border-radius: 24px 24px 0 0; }
    @media (max-width: 480px) { #bbc-quiz-ultra { padding: 30px 20px; margin: 20px 10px; border-radius: 20px; } .quiz-banner { height: 130px; margin: -30px -20px 20px -20px; width: calc(100% + 40px); } .quiz-banner img { border-radius: 20px 20px 0 0; } .timer-pill { padding: 6px 14px; font-size: 12px; } .q-text { font-size: 15px; } }
    .instruction-box { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 16px; padding: 20px; margin-bottom: 30px; }
    .btn-start { background: #007bff; color: white; border: none; padding: 18px; border-radius: 16px; font-weight: 700; cursor: pointer; width: 100%; font-size: 16px; }
    .q-header { margin-bottom: 25px; }
    .q-progress-bg { width: 100%; height: 6px; background: #f1f5f9; border-radius: 10px; overflow: hidden; }
    #q-progress-bar { height: 100%; background: #007bff; width: 0%; transition: 0.4s ease; }
    #q-status { font-size: 12px; color: #94a3b8; text-align: right; margin: 8px 0 0 0; font-weight: 700; }
    .q-text { font-size: 16px; font-weight: 400; color: #1e293b; margin-bottom: 30px; line-height: 1.4; }
    .btn-opt { display: block; width: 100%; padding: 18px; margin: 12px 0; border: 1px solid #e2e8f0; border-radius: 16px; background: #fff; cursor: pointer; text-align: left; font-size: 16px; color: #475569; }
    .btn-opt:hover:not(:disabled) { border-color: #cbd5e1; }
    .btn-opt.is-selected { border-color: #007bff !important; background: #f0f7ff !important; color: #007bff !important; }
    .btn-opt:disabled { opacity: 0.7; }
    .input-text { display: block; margin: 0 auto 15px auto; width: 100%; padding: 18px; border: 1px solid #e2e8f0; border-radius: 16px; font-size: 16px; outline: none; box-sizing: border-box; text-align: center; }
    .btn-submit-q { display: block; margin: 0 auto; background: #007bff; color: #fff; border: none; padding: 18px; border-radius: 16px; width: 100%; font-weight: 700; cursor: pointer; }
    #q-feedback { margin-top: 20px; display: none; padding: 18px; border-radius: 16px; font-size: 15px; font-weight: 600; }
    .alert-win { background: #dcfce7; color: #166534; }
    .alert-loss { background: #fee2e2; color: #991b1b; }
    .final-score { font-size: 80px; font-weight: 900; color: #007bff; margin: 15px 0; }
    .btn-retry { background: #1e293b; color: #fff; border: none; padding: 16px 40px; border-radius: 50px; cursor: pointer; font-weight: 700; margin-top: 25px; }
    .spinner { width: 40px; height: 40px; border: 4px solid #f3f3f3; border-top: 4px solid #007bff; border-radius: 50%; animation: spin 1s linear infinite; }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
</style>

<script is:inline>
(function() {
    const questions = [
        { type: "mcq", q: "Kamu merasa enggak enak badan, tapi kamu nggak tahu pasti sakit apa.<br><br><i>Apa ungkapan yang sesuai untuk 'Gak enak badan' dalam bahasa Inggris?<i>", opts: ["I'm back on my feet", "I'm feeling under the weather", "I feel not delicious body"], a: "I'm feeling under the weather" },
        { type: "mcq", q: "Punggungmu terasa pegal atau encok setelah mengangkat sesuatu yang berat.<br><br><i>Apa 'Expressions' yang tepat?<i>", opts: ["My back is killing me", "My leg is numb", "I have a headache"], a: "My back is killing me" },
        { type: "mcq", q: "Hidungmu rasanya tersumbat sampai susah napas karena flu berat.<br><br><i>Apa 'Expressions' yang tepat?<i>", opts: ["My nose is runny", "I'm stuffed up", "I have a cough"], a: "I'm stuffed up" },
        { type: "mcq", q: "Apa 'Expressions' yang tepat untuk mendoakan seseorang supaya dia lekas sembuh?", opts: ["Are you okay?", "Take some rest", "Speedy recovery"], a: "Speedy recovery" },
        { type: "mcq", q: "Apa bahasa Inggrisnya 'aku ngos-ngosan' atau 'aku kehabisan nafas' karena kecapean?", opts: ["I'm feeling run-down", "I'm out of breath", "I'm feeling a bit off"], a: "I'm out of breath" },
        { type: "mcq", q: "Kamu merasa pusing banget dan mata terasa berkunang-kunang seperti mau pingsan.<br><br><i>Apa 'Expressions' yang tepat?<i>", opts: ["I have stomachache", "My throat is sore", "I'm feeling faint"], a: "I'm feeling faint" },
        { type: "mcq", q: "Apa bahasa Inggrisnya 'Aku alergi udang'?", opts: ["I'm allergic to shrimp", "I coming down with shrimp", "I'm sensitive to seafood"], a: "I'm allergic to shrimp" },
        { type: "fill", q: "<b>You:</b> 'I think, I'm (...) because my head is boiling and I've been sneezing since this morning.'</br></br><i>(Petunjuk: Kamu merasa seperti mau sakit atau merasakan gejala awal)</i>", a: "coming down with something / Coming down with something" },
        { type: "fill", q: "<b>You:</b> 'I sat on the floor for too long, and now (...). Oh my god! I can't feel my toes!'</br></br><i>(Petunjuk: Apa bahasa Inggrisnya 'kakiku kesemutan')</i>", a: "My leg is numb / my leg is numb / My leg is numb / my leg is numb" },
        { type: "fill", q: "<b>You:</b> 'I shouted too much at the concert last night. Today, (...) and I can't speak clearly.'</br></br><i>(Petunjuk: Apa bahasa Inggrisnya 'tenggoranku sakit')</i>", a: "My throat is sore / my throat is sore" },
        { type: "fill", q: "<b>You:</b> 'It's very hot outside. Make sure to drink a lot of water and (...).'</br></br><i>(Petunjuk: Apa bahasa Inggrisnya 'Tetap jaga cairan tubuh')</i>", a: "Stay hydrated / stay hydrated" },
        { type: "fill", q: "<b>You:</b> 'I've been working for 15 hours non-stop and now I'm feeling (...).'</br></br><i>(Petunjuk: Bahasa Inggrisnya 'Kecapean parah')</i>", a: "run-down / Run-down" },
        { type: "fill", q: "<b>You:</b> 'Thank you for the soup. I drank it and slept all day. Now, I feel (...).',</br></br><i>(Petunjuk: Bahasa Inggrisnya 'enakan' atau 'mendingan')</i>", a: "much better / Much better" },
        { type: "listening", q: "<b>Dengarkan!</b><br>Apa yang harus dilakukan oleh 'Person B'?", audio: "audio/Audio Quiz_Healthandunwell_01.MP3", opts: ["She needs to eat some food", "She needs to sleep for a while", "She needs to drink water" ], a: "She needs to sleep for a while" },
        { type: "listening", q: "<b>Dengarkan!</b><br><i>Kenapa 'Person B' menolak makanan yang ditawarkan 'Person A?'</i>", audio: "audio/Audio Quiz_Healthandunwell_02.MP3", opts: ["Because she's on diet", "Because she's not hungry", "Because her stomach hurts and she fell nauseous"], a: "Because her stomach hurts and she fell nauseous" },
    ];

    function shuffleQuestions(array) {
        for (let i = array.length - 1; i > 0; i--) {
            const j = Math.floor(Math.random() * (i + 1));
            [array[i], array[j]] = [array[j], array[i]];
        }
    }

    shuffleQuestions(questions);

    let current = 0, score = 0, timeLeft = 300, timerId = null;

    function initQuiz() {
        setTimeout(() => {
            document.getElementById('quiz-loader').style.display = 'none';
            document.getElementById('quiz-welcome').style.display = 'block';
        }, 1200);
    }

    document.getElementById('start-btn').onclick = function() {
        document.getElementById('quiz-welcome').style.display = 'none';
        document.getElementById('quiz-main-content').style.display = 'block';
        document.getElementById('quiz-timer-container').style.display = 'flex';
        startTimer();
        showQuestion();
    };

    function startTimer() {
        const display = document.getElementById('timer-display');
        const pill = document.querySelector('.timer-pill');
        timerId = setInterval(() => {
            timeLeft--;
            let mins = Math.floor(timeLeft / 60), secs = timeLeft % 60;
            display.innerText = `${mins.toString().padStart(2, '0')}:${secs.toString().padStart(2, '0')}`;
            if (timeLeft <= 30) pill.classList.add('timer-low');
            if (timeLeft <= 0) { clearInterval(timerId); showTimeOut(); }
        }, 1000);
    }

    function showTimeOut() {
        document.querySelector('.q-header').style.display = 'none';
        document.getElementById('q-body-area').style.display = 'none';
        document.getElementById('quiz-timer-container').style.display = 'none';
        document.getElementById('q-timeout').style.display = 'block';
        document.getElementById('snd-wrong').play().catch(() => {});
    }

    function showQuestion() {
        const q = questions[current];
        const contentArea = document.getElementById('q-content');
        document.getElementById('q-feedback').style.display = 'none';
        document.getElementById('q-status').innerText = `Question ${current + 1} of ${questions.length}`;
        document.getElementById('q-progress-bar').style.width = ((current + 1) / questions.length * 100) + "%";
        
        let html = `<div class="q-text">${q.q}</div>`;
        if (q.type === "listening") {
            html = `<div style="margin-bottom:20px;"><audio controls autoplay><source src="${q.audio}"></audio></div>` + html;
        }
        if (q.type === "mcq" || q.type === "listening") {
            q.opts.forEach(o => { html += `<button class="btn-opt" onclick="verify('${o.replace(/'/g, "\\'")}', event)">${o}</button>`; });
        } else {
            html += `<div style="text-align: center; width: 100%;">
                        <input type="text" id="ans-input" class="input-text" placeholder="Type answer..." autofocus>
                        <button class="btn-submit-q" id="submit-btn">Submit</button>
                     </div>`;
        }
        contentArea.innerHTML = html;
        const input = document.getElementById('ans-input');
        if (input) {
            input.addEventListener("keypress", (e) => { if (e.key === "Enter") verify(input.value); });
            document.getElementById('submit-btn').onclick = () => verify(input.value);
        }
    }

    window.verify = function(userAns, e) {
        if (!userAns || document.querySelectorAll('.btn-opt:disabled').length > 0) return;
        const q = questions[current], feedbackArea = document.getElementById('q-feedback');
        if (e && e.currentTarget && e.currentTarget.classList.contains('btn-opt')) e.currentTarget.classList.add('is-selected');

        const normalize = (t) => t.toLowerCase().replace(/[.,/#!$%^&*;:{}=\-_`~()]/g, "").replace(/\s+/g, " ").trim();
        const cleanUserAns = normalize(userAns);
        const isCorrect = q.a.split('/').map(ans => normalize(ans)).includes(cleanUserAns);

        document.querySelectorAll('.btn-opt, .btn-submit-q').forEach(b => b.disabled = true);
        feedbackArea.style.display = 'block';

        if (isCorrect) {
            score++;
            feedbackArea.innerHTML = "✅ Correct!"; 
            feedbackArea.className = "alert-win";
            document.getElementById('snd-correct').play().catch(() => {});
        } else {
            feedbackArea.innerHTML = `❌ Wrong. Answer: <strong>${q.a.split('/')[0]}</strong>`;
            feedbackArea.className = "alert-loss";
            document.getElementById('snd-wrong').play().catch(() => {});
        }

        setTimeout(() => {
            current++;
            if (current < questions.length) {
                showQuestion();
            } else {
                showResult();
            }
        }, 1400);
    };

    function showResult() {
        clearInterval(timerId);
        // MATIKAN ELEMEN INTERFACE LAIN
        document.getElementById('quiz-timer-container').style.display = 'none';
        document.querySelector('.q-header').style.display = 'none';
        document.getElementById('q-body-area').style.display = 'none';
        
        // TAMPILKAN HASIL
        const resArea = document.getElementById('q-result');
        resArea.style.display = 'block';
        document.getElementById('score-num').innerText = score;

        let feedbackMsg = "";
        if (score === questions.length) {
            feedbackMsg = "PERFECT! Congrats, you did it! 🌟";
            document.getElementById('snd-perfect').play().catch(() => {});
            confetti({
                particleCount: 200,
                spread: 90,
                origin: { y: 0.6 },
                colors: ['#007bff', '#28a745', '#ffc107']
            });
        } else if (score >= 12) {
            feedbackMsg = "Excellent! You did a good job! 🔥";
        } else if (score >= 8) {
            feedbackMsg = "Not bad! Keep practicing a lot! 👍";
        } else {
            feedbackMsg = "Don't give up! Let's give it a try again. 💪";
        }

        document.getElementById('feedback-summary').innerText = feedbackMsg;
    }

    initQuiz();
})();
</script>
</body>
</html>