<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>500 English Expressions - BBC Pare</title>
</head>
<body>
    <div class="ebook-container">
        <header class="header">
            <span class="bold">500 English Expressions</span>
            <span class="vol">Vol 1</span>
        </header>

        <section class="title-section">
            <h1>Greetings & Small Talk</h1>
            <p>Klik pada kolom expressions untuk mendengar cara bacanya</p>
        </section>

        <div class="table-wrapper">
            <table class="expression-table">
                <thead>
                    <tr>
                        <th>Bahasa Inggris</th>
                        <th>Cara Baca</th>
                        <th>Terjemahan</th>
                    </tr>
                </thead>
                <tbody>
                    {expressions.map((item) => (
                        <tr>
                            <td class="eng eng-clickable" onclick={`playAudio('${item.audio}')`}>
                                {item.eng}
                            </td>
                            <td class="read">{item.read}</td>
                            <td class="tr">{item.tr}</td>
                        </tr>
                    ))}
                </tbody>
            </table>
        </div>

        <nav class="page-navigation">
            <div class="nav-item left">
                <a href="/halaman-02" class="nav-link">
                    <span class="chevron">&laquo;</span> Prev Page
                </a>
            </div>
            <div class="nav-item center">
                <a href="/daftar-isi" class="nav-link">Daftar Isi</a>
            </div>
            <div class="nav-item right">
                <a href="/halaman-04" class="nav-link">
                    Next Page <span class="chevron">&raquo;</span>
                </a>
            </div>
        </nav>

        <footer class="footer">
            <div class="footer-left">
                <span>📸 @kampunginggrisbbc</span>
                <span>🌐 www.kampunginggrisbbc.com</span>
            </div>
            <div class="page-number">03</div>
        </footer>
    </div>

    <script is:inline>
        function playAudio(url) {
            const audio = new Audio(url);
            audio.play().catch(err => {
                console.error("Audio play blocked or file not found:", err);
            });
        }
    </script>
</body>
</html>

<style>
    :root {
        --primary-blue: #002677;
        --yellow-header: #ffff00;
        --border-color: #d1d1d1;
    }

    body {
        margin: 0;
        padding: 0; /* Padding dihilangkan agar container bisa menyentuh pinggir layar mobile */
        background-color: #f0f0f0;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        display: flex;
        justify-content: center;
        min-height: 100vh;
    }

    .ebook-container {
        width: 100%;
        max-width: 800px; /* Batas maksimal desktop tetap terjaga */
        background-color: white;
        background-image: url('public/images/background_ebook_expressions.webp');
        background-size: cover;
        background-position: center;
        padding: 60px 40px;
        box-shadow: 0 0 15px rgba(0,0,0,0.1);
        position: relative;
        min-height: 100vh; /* Mengikuti tinggi layar perangkat */
        display: flex;
        flex-direction: column;
        box-sizing: border-box; /* Menghitung padding ke dalam lebar */
    }

    /* Pengaturan Tabel Dinamis */
    .table-wrapper {
        width: 100%;
        overflow-x: auto; /* Memungkinkan scroll horizontal jika teks sangat panjang di layar kecil */
        -webkit-overflow-scrolling: touch; /* Scroll halus di iOS */
    }

    .expression-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 0px;
        background-color: rgba(255, 255, 255, 0.9);
        table-layout: auto; /* Dinamis mengikuti konten */
    }

    /* ... Sisa CSS Anda dioptimalkan di bagian media query di bawah ... */

    .page-navigation {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
    padding: 20px 0;
    width: 100%;
}

/* Membagi ruang menjadi 3 bagian yang sama rata */
.nav-item {
    flex: 1; 
}

.nav-item.left {
    text-align: left;
}

.nav-item.center {
    text-align: center;
}

.nav-item.right {
    text-align: right;
}

.nav-link {
    text-decoration: none;
    color: #444; /* Sesuaikan dengan warna di gambar Anda */
    font-weight: 600;
    font-size: clamp(12px, 3vw, 16px); /* Ukuran dinamis untuk mobile & desktop */
    transition: color 0.2s ease;
}

.nav-link:hover {
    color: var(--primary-blue);
}

/* Penyesuaian untuk layar sangat kecil */
@media (max-width: 480px) {
    .page-navigation {
        padding: 15px 5px;
    }
    .nav-link {
        font-size: 11px;
    }
}

    .header { display: flex; justify-content: space-between; font-size: 14px; border-bottom: 2px solid #000; padding-bottom: 5px; margin-bottom: 40px; }
    .title-section { text-align: center; margin-bottom: 30px; }
    .title-section h1 { margin: 0; font-size: 32px; font-weight: bold; }
    .expression-table th { background-color: var(--yellow-header); border: 1px solid var(--border-color); padding: 12px; font-size: 14px; }
    .expression-table td { border: 1px solid var(--border-color); padding: 10px; text-align: center; font-size: 12px; }
    .eng-clickable { font-weight: 600; cursor: pointer; color: var(--primary-blue); transition: background 0.2s; }
    .eng-clickable:hover { background-color: rgba(0, 38, 119, 0.05); }
    .read { font-style: italic; color: #555; }

    .footer {
        background-color: var(--primary-blue);
        color: white;
        padding: 10px 20px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        border-radius: 50px;
        margin-top: 20px;
        gap: 15px; /* Memberi jarak antara info medsos dan nomor halaman */
    }

    .footer-left {
        display: flex;
        flex-direction: row; /* MEMBUAT SEJAJAR KESAMPING */
        align-items: center;
        gap: 15px; /* Jarak antara ikon IG dan ikon Web */
        flex-wrap: nowrap; /* Mencegah teks turun ke bawah */
    }

    .footer-left span {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: clamp(9px, 2vw, 13px); /* Ukuran font dinamis agar tetap muat sejajar */
        white-space: nowrap;
    }

    .page-number {
        font-size: clamp(20px, 4vw, 32px);
        font-weight: bold;
        flex-shrink: 0;
    }

    /* PENYESUAIAN KHUSUS MOBILE */
    @media (max-width: 600px) {
        .footer {
            padding: 8px 15px;
            border-radius: 20px;
            gap: 10px;
        }

        .footer-left {
            gap: 8px; /* Jarak antar medsos dipersempit sedikit di mobile */
            overflow: hidden; /* Menjaga agar tidak merusak layout */
        }

        .footer-left span {
            font-size: 9px; /* Ukuran font dipatok kecil agar pasti sejajar */
        }
    }
</style>