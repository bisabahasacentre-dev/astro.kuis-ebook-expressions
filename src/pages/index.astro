---
// Bagian Frontmatter Astro
const title = "BBC Ultra Quiz - English Expressions";
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

<div id="bbc-quiz-ultra">
    <div id="quiz-loader" style="display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 300px;">
        <div class="spinner"></div>
        <p style="margin-top: 15px; color: #94a3b8; font-size: 14px; font-weight: 500;">Menyiapkan kuis untuk Anda...</p>
    </div>
    <div id="quiz-main-content" style="display: none;">
        <div class="q-header">
            <div class="q-progress-bg">
                <div id="q-progress-bar"></div>
            </div>
            <div id="q-status">Memuat soal...</div>
        </div>

        <div id="q-body-area">
            <div id="q-content"></div>
            <div id="q-feedback"></div>
        </div>

        <div id="q-result" style="display: none;">
            <h2 style="color: #007bff; margin: 0;">Quiz Completed!</h2>
            <div class="final-score">
                <span id="score-num">0</span><small style="font-size: 20px; color: #94a3b8;">/15</small>
            </div>
            <p id="feedback-summary" style="color: #64748b; font-weight: 500;"></p>
            <button onclick="window.location.reload()" class="btn-retry">Ulangi Kuis</button>
        </div>
    </div>

    <audio id="snd-correct" preload="auto" src="https://assets.mixkit.co/active_storage/sfx/2000/2000-preview.mp3"></audio>
    <audio id="snd-wrong" preload="auto" src="https://assets.mixkit.co/active_storage/sfx/2003/2003-preview.mp3"></audio>
</div>

<style is:global>
    /* CSS ANIMASI SPINNER */
    .spinner {
        width: 40px;
        height: 40px;
        border: 4px solid #f3f3f3;
        border-top: 4px solid #007bff;
        border-radius: 50%;
        animation: spin 1s linear infinite;
    }

    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    /* CSS UTAMA */
    #bbc-quiz-ultra {
        font-family: 'Poppins', sans-serif;
        max-width: 500px;
        margin: 20px auto;
        background: #ffffff;
        border-radius: 20px;
        padding: 25px;
        box-shadow: 0 15px 35px rgba(0,0,0,0.08);
        border: 1px solid #eee;
        min-height: 350px;
        box-sizing: border-box;
    }
    .q-progress-bg { width: 100%; height: 8px; background: #f0f0f0; border-radius: 10px; overflow: hidden; }
    #q-progress-bar { height: 100%; background: #007bff; width: 0%; transition: 0.4s ease; }
    #q-status { font-size: 12px; color: #94a3b8; text-align: right; margin: 8px 0 20px 0; font-weight: 600; }
    .q-text { font-size: 1.1rem; font-weight: 600; color: #333; margin-bottom: 20px; text-align: left; line-height: 1.6; }
    
    .btn-opt {
        display: block; width: 100%; padding: 14px 18px; margin: 10px 0;
        border: 2px solid #f1f3f5; border-radius: 12px; background: #fff;
        cursor: pointer; text-align: left; font-size: 15px; font-family: inherit; 
        transition: all 0.2s; color: #495057; font-weight: 500;
    }
    .btn-opt:hover:not(:disabled) { border-color: #007bff; background: #f0f7ff; color: #007bff; }
    .btn-opt:disabled { opacity: 0.7; cursor: not-allowed; }
    
    .input-text { width: 100%; padding: 15px; border: 2px solid #eee; border-radius: 12px; font-size: 16px; margin-bottom: 15px; outline: none; box-sizing: border-box; }
    .btn-submit-q { background: #007bff; color: #fff; border: none; padding: 15px; border-radius: 12px; width: 100%; font-weight: 700; cursor: pointer; }
    
    #q-feedback { margin-top: 20px; display: none; padding: 15px; border-radius: 12px; font-size: 14px; font-weight: 600; }
    .alert-win { background: #d4edda; color: #155724; border: 1px solid #c3e6cb; }
    .alert-loss { background: #f8d7da; color: #721c24; border: 1px solid #f5c6cb; }
    
    .final-score { font-size: 60px; font-weight: 800; color: #007bff; margin: 10px 0; }
    .btn-retry { background: #1e293b; color: #fff; border: none; padding: 14px 35px; border-radius: 50px; cursor: pointer; font-weight: 600; margin-top: 20px; }
    
    .audio-player { background: #f8fafc; padding: 15px; border-radius: 12px; margin-bottom: 20px; border: 1px solid #e2e8f0; }
    audio { width: 100%; height: 35px; }
</style>

<script is:inline>
// Menggunakan is:inline agar window.verify bisa diakses oleh onclick di HTML dinamis
(function() {
    const questions = [
        { type: "mcq", q: "A: How do you do?<br>B: ___", opts: ["How do you do?", "I'm fine", "Pretty good"], a: "How do you do?" },
        { type: "mcq", q: "Apa yang kamu katakan ketika bertemu teman lama setelah lama tidak berjumpa?: ___", opts: ["Nice to meet you", "Long time no see!", "What's going on?"], a: "Long time no see!" },
        { type: "mcq", q: "A: What's up?<br>B: ___", opts: ["Not much", "How do you do?", "How are you?"], a: "Not much" },
        { type: "mcq", q: "A: How's life?<br>B: ___", opts: ["Pretty good", "See you", "How do you do?"], a: "Pretty good" },
        { type: "mcq", q: "Manakah yang digunakan ketika bertemu orang pertama kali?", opts: ["What's up?", "Nice to meet you", "How have you been?"], a: "Nice to meet you" },
        { type: "mcq", q: "A: Catch you later!<br>B: ___", opts: ["See you!", "Good to see you!", "Not much"], a: "See you!" },
        { type: "fill", q: "Complete the phrase: 'It's been ___!", a: "ages" },
        { type: "fill", q: "Sibuk seperti biasanya: 'Busy as ___.'", a: "always" },
        { type: "fill", q: "Menanyakan kondisi: 'How ___ you been?'", a: "have" },
        { type: "fill", q: "Ketika kabarmu b aja atau tidak ada masalah: 'Can't ___.'", a: "complain" },
        { type: "fill", q: "Greeting: 'What's going ___?'", a: "on" },
        { type: "fill", q: "Daily small talk: 'How is your ___?'", a: "day" },
        { type: "listening", q: "Listen! What greeting did you hear?", audio: "https://www.kampunginggrisbbc.com/wp-content/uploads/2026/03/Audio-Quiz_GreetnSmalltalk_01.mp3", opts: ["How's life?", "What's up?", "How are you?"], a: "How's life?" },
        { type: "listening", q: "Listen! What is the response?", audio: "https://www.kampunginggrisbbc.com/wp-content/uploads/2026/03/Audio-Quiz_GreetnSmalltalk_02.mp3", opts: ["What is up", "No idea", "Pretty good"], a: "Pretty good" },
        { type: "listening", q: "Listen! What farewell is used?", audio: "https://www.kampunginggrisbbc.com/wp-content/uploads/2026/03/Audio-Quiz_GreetnSmalltalk_03.mp3", opts: ["Have a good day", "See you", "Catch you later"], a: "Have a good day" }
    ];

    let current = 0;
    let score = 0;

    function initQuiz() {
        const loader = document.getElementById('quiz-loader');
        const mainContent = document.getElementById('quiz-main-content');

        questions.forEach(q => {
            if (q.type === "listening") {
                const link = document.createElement('link');
                link.rel = 'preload';
                link.as = 'audio';
                link.href = q.audio;
                document.head.appendChild(link);
            }
        });

        setTimeout(() => {
            if(loader) loader.style.display = 'none';
            if(mainContent) mainContent.style.display = 'block';
            showQuestion();
        }, 1200);
    }

    function showQuestion() {
        const q = questions[current];
        const contentArea = document.getElementById('q-content');
        const feedbackArea = document.getElementById('q-feedback');
        
        if(feedbackArea) feedbackArea.style.display = 'none';
        document.getElementById('q-status').innerText = `Question ${current + 1} of ${questions.length}`;
        document.getElementById('q-progress-bar').style.width = ((current + 1) / questions.length * 100) + "%";

        let html = `<div class="q-text">${q.q}</div>`;

        if (q.type === "listening") {
            html = `<div class="audio-player"><audio controls preload="auto" autoplay><source src="${q.audio}"></audio></div>` + html;
        }

        if (q.type === "mcq" || q.type === "listening") {
            q.opts.forEach(o => {
                html += `<button class="btn-opt" onclick="verify('${o.replace(/'/g, "\\'")}')">${o}</button>`;
            });
        } else {
            html += `<input type="text" id="ans-input" class="input-text" placeholder="Type answer & press Enter..." autofocus>
                     <button class="btn-submit-q" id="submit-btn">Submit Answer</button>`;
        }

        contentArea.innerHTML = html;

        const input = document.getElementById('ans-input');
        if (input) {
            input.addEventListener("keypress", function(e) { if (e.key === "Enter") verify(input.value); });
            document.getElementById('submit-btn').onclick = () => verify(input.value);
        }
    }

    window.verify = function(userAns) {
        if (!userAns || document.querySelectorAll('.btn-opt:disabled').length > 0) return;
        
        const q = questions[current];
        const feedbackArea = document.getElementById('q-feedback');
        const isCorrect = userAns.toLowerCase().trim() === q.a.toLowerCase();

        document.querySelectorAll('.btn-opt, .btn-submit-q').forEach(b => b.disabled = true);

        feedbackArea.style.display = 'block';
        if (isCorrect) {
            score++;
            feedbackArea.innerHTML = "✅ Correct! Well done.";
            feedbackArea.className = "alert-win";
            document.getElementById('snd-correct').play().catch(() => {});
        } else {
            feedbackArea.innerHTML = `❌ Incorrect. Correct answer: <strong>${q.a}</strong>`;
            feedbackArea.className = "alert-loss";
            document.getElementById('snd-wrong').play().catch(() => {});
        }

        setTimeout(() => {
            current++;
            if (current < questions.length) {
                showQuestion();
            } else {
                showResult();
            }
        }, 1800);
    };

    function showResult() {
        document.getElementById('q-body-area').style.display = 'none';
        document.querySelector('.q-header').style.display = 'none';
        document.getElementById('q-result').style.display = 'block';
        document.getElementById('score-num').innerText = score;
        let msg = score >= 12 ? "Perfect! You're an expert." : (score >= 8 ? "Good job! Keep it up." : "Don't give up, keep practicing!");
        document.getElementById('feedback-summary').innerText = msg;
    }

    if (document.readyState === "complete" || document.readyState === "interactive") {
        initQuiz();
    } else {
        document.addEventListener('DOMContentLoaded', initQuiz);
    }
})();
</script>

</body>
</html>