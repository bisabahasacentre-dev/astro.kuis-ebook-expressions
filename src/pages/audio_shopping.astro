---
const title = "Interactive Audio Lesson - BBC Pare";
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="container">
    <div class="quiz-banner">
        <img 
            src="/Images/Banner-kuis-web.webp" 
            alt="1000 Common English Expressions"
            loading="lazy"
        />
    </div>

    <div class="header-player">
        <h2>Unit 3 : Shopping</h2>
        <p style="font-size: 0.75rem; color: #64748b; margin-top: -10px; margin-bottom: 15px;">
            Putar audio dan baca text dialognya lalu ikuti cara pelafalannya!
        </p>
        <audio id="mainAudio" controls preload="metadata">
            <source src="audio/audio_shopping.mp3" type="audio/mpeg">
        </audio>

        <div class="speed-wrapper">
            <button class="btn-speed" onclick="setPlaySpeed(0.5, this)">0.5x</button>
            <button class="btn-speed" onclick="setPlaySpeed(0.8, this)">0.8x</button>
            <button class="btn-speed active" onclick="setPlaySpeed(1.0, this)">Normal</button>
            <button class="btn-speed" onclick="setPlaySpeed(1.2, this)">1.2x</button>
        </div>
    </div>

    <div class="transcript-container" id="transcriptBody">
        <div class="dialog-card" data-time="0">
            <span class="speaker">Leo</span>
            <span class="message">Wow, this mall is massive! I think I’m gonna window shopping for a while.</span>
        </div>

        <div class="dialog-card" data-time="6">
            <span class="speaker">Daniel</span>
            <span class="message">Me too, but what if we shop around first to see the best deals?</span>
        </div>

        <div class="dialog-card" data-time="11">
            <span class="speaker">Staff</span>
            <span class="message">Welcome to our store! How may I help you?</span>
        </div>
        
        <div class="dialog-card" data-time="15">
            <span class="speaker">Leo</span>
            <span class="message">Oh, I'm just looking, thanks. Just checking the new arrivals.</span>
        </div>

        <div class="dialog-card" data-time="20">
            <span class="speaker">Daniel</span>
            <span class="message">Excuse me, I love this shirt. Do you have this in a medium size?</span>
        </div>

        <div class="dialog-card" data-time="25">
            <span class="speaker">Staff</span>
            <span class="message">I'll check... yes, here it is!</span>
        </div>

        <div class="dialog-card" data-time="30">
            <span class="speaker">Daniel</span>
            <span class="message">Perfect. Can I try this on?</span>
        </div>

        <div class="dialog-card" data-time="33">
            <span class="speaker">Staff</span>
            <span class="message">Of course! Oh, wait! We're a bit busy, so make a line, please.</span>
        </div>

        <div class="dialog-card" data-time="38">
            <span class="speaker">Another Customer</span>
            <span class="message">Excuse me, could I return this, please? It has a small stain.</span>
        </div>

        <div class="dialog-card" data-time="44">
            <span class="speaker">Daniel</span>
            <span class="message">It fits! How much is this?</span>
        </div>

        <div class="dialog-card" data-time="47">
            <span class="speaker">Staff</span>
            <span class="message">That one is $120.</span>
        </div>

        <div class="dialog-card" data-time="50">
            <span class="speaker">Daniel</span>
            <span class="message"> Hmm, is it on sale? I saw a discount tag on the rack.</span>
        </div>

        <div class="dialog-card" data-time="55">
            <span class="speaker">Staff</span>
            <span class="message">Ah, you're right! With the discount, it's a bargain!</span>
        </div>

        <div class="dialog-card" data-time="60">
            <span class="speaker">Leo</span>
            <span class="message">Really? I still think it's too expensive! for a simple shirt.</span>
        </div>

        <div class="dialog-card" data-time="64">
            <span class="speaker">Daniel</span>
            <span class="message">Actually, for this brand, it's quite affordable. Can I get a discount?</span>
        </div>

        <div class="dialog-card" data-time="70">
            <span class="speaker">Staff</span>
            <span class="message">Currently we have 20% off for that item</span>
        </div>

        <div class="dialog-card" data-time="74">
            <span class="speaker">Daniel</span>
            <span class="message">Alright, I'll take it then. Is there a warranty for the fabric?</span>
        </div>

        <div class="dialog-card" data-time="79">
            <span class="speaker">Staff</span>
            <span class="message"> Yes, it has. Don't worry sir</span>
        </div>
        
        <div class="dialog-card" data-time="82">
            <span class="speaker">Daniel</span>
            <span class="message">Wait, do you accept cash?</span>
        </div>

        <div class="dialog-card" data-time="84">
            <span class="speaker">Staff</span>
            <span class="message">Yes, we do. Would you like to pay by cash or credit card?</span>
        </div>

        <div class="dialog-card" data-time="89">
            <span class="speaker">Daniel</span>
            <span class="message">Well, can I pay by credit card? Because my cash is in the car.</span>
        </div>

        <div class="dialog-card" data-time="95">
            <span class="speaker">Daniel</span>
            <span class="message">Here, keep the change!</span>
        </div>
    </div>
</div>

<style is:global>
    /* Reset & Base Styling */
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

    :root {
        --primary: #4f46e5;
        --bg-body: #f8fafc;
        --bg-card: #ffffff;
        --text-main: #1e293b;
        --text-grey: #64748b;
        --border: #e2e8f0;
        --active-light: #eef2ff;
    }

    body {
        font-family: 'Inter', sans-serif;
        background-color: var(--bg-body);
        margin: 0;
        padding: 0;
        display: flex;
        justify-content: center;
    }

    .quiz-banner {
        width: 100%;
        margin-bottom: 25px; 
        line-height: 0;
        overflow: hidden;
        border-radius: 24px 24px 0 0;
    }

    .quiz-banner img {
        width: 100%;
        height: auto;
        display: block;
        object-fit: contain;
    }

    /* Container */
    .container {
        width: 100%;
        max-width: 700px;
        background: var(--bg-card);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    /* Sticky Header */
    .header-player {
        position: sticky;
        top: 0;
        background: var(--bg-card);
        padding: 0 20px 20px 20px;
        border-bottom: 1px solid var(--border);
        z-index: 100;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    h2 { margin: 0 0 15px 0; font-size: 1.1rem; font-weight: 700; color: var(--primary); }
    audio { width: 100%; height: 44px; margin-bottom: 15px; }

    /* Speed Control & Transcript (Tidak Ada Perubahan Desain) */
    .speed-wrapper { display: flex; align-items: center; justify-content: space-between; gap: 8px; background: #f8fafc; padding: 6px; border-radius: 12px; }
    .btn-speed { flex: 1; background: transparent; border: none; padding: 8px 5px; border-radius: 8px; cursor: pointer; font-size: 0.75rem; font-weight: 600; color: var(--text-grey); transition: 0.2s; }
    .btn-speed.active { background: var(--primary); color: white; }
    .transcript-container { flex: 1; padding: 15px; overflow-y: auto; scroll-behavior: smooth; }
    .dialog-card { background: #ffffff; border: 1px solid var(--border); padding: 16px; border-radius: 14px; margin-bottom: 12px; cursor: pointer; transition: all 0.3s ease; }
    .dialog-card.active { background-color: var(--active-light); border-color: var(--primary); transform: scale(0.98); }
    .speaker { display: block; font-size: 0.7rem; font-weight: 700; color: var(--text-grey); text-transform: uppercase; margin-bottom: 6px; }
    .message { font-size: 1rem; line-height: 1.5; color: var(--text-main); }

    @media (min-width: 768px) {
        body { padding: 40px 20px; }
        .container { min-height: auto; height: 85vh; border-radius: 24px; border: 1px solid var(--border); box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); }
    }

    @media (max-width: 480px) {
        .quiz-banner { border-radius: 20px 20px 0 0; }
    }
</style>

<script is:inline>
    const audio = document.getElementById('mainAudio');
    const cards = document.querySelectorAll('.dialog-card');

    window.setPlaySpeed = function(rate, btn) {
        if (!audio) return;
        audio.playbackRate = rate;
        document.querySelectorAll('.btn-speed').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
    }

    cards.forEach(card => {
        card.addEventListener('click', () => {
            const time = parseFloat(card.getAttribute('data-time'));
            audio.currentTime = time;
            audio.play();
        });
    });

    let lastActive = -1;
    audio.addEventListener('timeupdate', () => {
        const now = audio.currentTime;
        let currentIdx = -1;
        cards.forEach((card, i) => {
            const start = parseFloat(card.getAttribute('data-time'));
            const next = cards[i + 1];
            const end = next ? parseFloat(next.getAttribute('data-time')) : Infinity;
            if (now >= start && now < end) currentIdx = i;
        });
        if (currentIdx !== -1 && currentIdx !== lastActive) {
            cards.forEach(c => c.classList.remove('active'));
            const activeCard = cards[currentIdx];
            activeCard.classList.add('active');
            activeCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
            lastActive = currentIdx;
        }
    });
</script>

</body>
</html>