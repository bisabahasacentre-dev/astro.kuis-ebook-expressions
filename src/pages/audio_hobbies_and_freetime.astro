---
const title = "Interactive Audio Lesson - BBC Pare";
---

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body>

<div class="container">
    <div class="quiz-banner">
        <img 
            src="/Images/Banner-kuis-web.webp" 
            alt="1000 Common English Expressions"
            loading="lazy"
        />
    </div>

    <div class="header-player">
        <h2>Unit 9 : Hobbies and Free Time</h2>
        <p style="font-size: 0.75rem; color: #64748b; margin-top: -10px; margin-bottom: 15px;">
            Putar audio dan baca text dialognya lalu ikuti cara pelafalannya!
        </p>
        <audio id="mainAudio" controls preload="metadata">
            <source src="audio/audio_hobbies.mp3" type="audio/mpeg">
        </audio>

        <div class="speed-wrapper">
            <button class="btn-speed" onclick="setPlaySpeed(0.5, this)">0.5x</button>
            <button class="btn-speed" onclick="setPlaySpeed(0.8, this)">0.8x</button>
            <button class="btn-speed active" onclick="setPlaySpeed(1.0, this)">Normal</button>
            <button class="btn-speed" onclick="setPlaySpeed(1.2, this)">1.2x</button>
        </div>
    </div>

    <div class="transcript-container" id="transcriptBody">
        <div class="dialog-card" data-time="1">
            <span class="speaker">Alex</span>
            <span class="message">Hey Sam, I'm bored at home today. My watchlist is empty.</span>
        </div>

        <div class="dialog-card" data-time="7">
            <span class="speaker">Sam</span>
            <span class="message">Same here. So, what do you usually do to kill time?</span>
        </div>

        <div class="dialog-card" data-time="11">
            <span class="speaker">Alex</span>
            <span class="message">Just chilling. By the way, what's your hobby?</span>
        </div>
        
        <div class="dialog-card" data-time="15">
            <span class="speaker">Sam</span>
            <span class="message">I'm into movies, especially sci-fi. How about you?</span>
        </div>

        <div class="dialog-card" data-time="20">
            <span class="speaker">Alex</span>
            <span class="message">I like music, and lately I've been reading a lot.</span>
        </div>

        <div class="dialog-card" data-time="24">
            <span class="speaker">Sam</span>
            <span class="message">Nice! What are you reading?</span>
        </div>

        <div class="dialog-card" data-time="27">
            <span class="speaker">Alex</span>
            <span class="message">Mystery novels. Are you into K-pop too? It's everywhere.</span>
        </div>

        <div class="dialog-card" data-time="33">
            <span class="speaker">Sam</span>
            <span class="message">A bit, but I prefer rock. Anyway, do you play games?</span>
        </div>

        <div class="dialog-card" data-time="38">
            <span class="speaker">Alex</span>
            <span class="message">Sometimes, but my brother is the real gamer.</span>
        </div>

        <div class="dialog-card" data-time="42">
            <span class="speaker">Sam</span>
            <span class="message">Haha, I get that. I need a holiday though. Work is tough.</span>
        </div>

        <div class="dialog-card" data-time="49">
            <span class="speaker">Alex</span>
            <span class="message">Same here. I love going to the beach to relax.</span>
        </div>

        <div class="dialog-card" data-time="53">
            <span class="speaker">Sam</span>
            <span class="message">That sounds fun! We should plan a trip then.</span>
        </div>

        <div class="dialog-card" data-time="56">
            <span class="speaker">Alex</span>
            <span class="message"> Sure. Let's talk about it soon.</span>
        </div>

        <div class="dialog-card" data-time="59">
            <span class="speaker">Sam</span>
            <span class="message">Will you be free on Saturday?</span>
        </div>

        <div class="dialog-card" data-time="62">
            <span class="speaker">Alex</span>
            <span class="message">I can't because my cousin is visiting.</span>
        </div>

        <div class="dialog-card" data-time="65">
            <span class="speaker">Sam</span>
            <span class="message">How about tonight?</span>
        </div>

        <div class="dialog-card" data-time="67">
            <span class="speaker">Alex</span>
            <span class="message"> I'm afraid I can't because I have something to do.</span>
        </div> 

        <div class="dialog-card" data-time="71">
            <span class="speaker">Sam</span>
            <span class="message">Alright, nevermind though.</span>
        </div>

        <div class="dialog-card" data-time="74">
            <span class="speaker">Alex</span>
            <span class="message">What if we talk about it tomorrow?</span>
        </div>

        <div class="dialog-card" data-time="76">
            <span class="speaker">Sam</span>
            <span class="message"> I think that's a good idea.</span>
        </div>
    </div>
</div>

<style is:global>
    /* Reset & Base Styling */
    * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

    :root {
        --primary: #4f46e5;
        --bg-body: #f8fafc;
        --bg-card: #ffffff;
        --text-main: #1e293b;
        --text-grey: #64748b;
        --border: #e2e8f0;
        --active-light: #eef2ff;
    }

    body {
        font-family: 'Inter', sans-serif;
        background-color: var(--bg-body);
        margin: 0;
        padding: 0;
        display: flex;
        justify-content: center;
    }

    .quiz-banner {
        width: 100%;
        margin-bottom: 25px; 
        line-height: 0;
        overflow: hidden;
        border-radius: 24px 24px 0 0;
    }

    .quiz-banner img {
        width: 100%;
        height: auto;
        display: block;
        object-fit: contain;
    }

    /* Container */
    .container {
        width: 100%;
        max-width: 700px;
        background: var(--bg-card);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
    }

    /* Sticky Header */
    .header-player {
        position: sticky;
        top: 0;
        background: var(--bg-card);
        padding: 0 20px 20px 20px;
        border-bottom: 1px solid var(--border);
        z-index: 100;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
    }

    h2 { margin: 0 0 15px 0; font-size: 1.1rem; font-weight: 700; color: var(--primary); }
    audio { width: 100%; height: 44px; margin-bottom: 15px; }

    /* Speed Control & Transcript (Tidak Ada Perubahan Desain) */
    .speed-wrapper { display: flex; align-items: center; justify-content: space-between; gap: 8px; background: #f8fafc; padding: 6px; border-radius: 12px; }
    .btn-speed { flex: 1; background: transparent; border: none; padding: 8px 5px; border-radius: 8px; cursor: pointer; font-size: 0.75rem; font-weight: 600; color: var(--text-grey); transition: 0.2s; }
    .btn-speed.active { background: var(--primary); color: white; }
    .transcript-container { flex: 1; padding: 15px; overflow-y: auto; scroll-behavior: smooth; }
    .dialog-card { background: #ffffff; border: 1px solid var(--border); padding: 16px; border-radius: 14px; margin-bottom: 12px; cursor: pointer; transition: all 0.3s ease; }
    .dialog-card.active { background-color: var(--active-light); border-color: var(--primary); transform: scale(0.98); }
    .speaker { display: block; font-size: 0.7rem; font-weight: 700; color: var(--text-grey); text-transform: uppercase; margin-bottom: 6px; }
    .message { font-size: 1rem; line-height: 1.5; color: var(--text-main); }

    @media (min-width: 768px) {
        body { padding: 40px 20px; }
        .container { min-height: auto; height: 85vh; border-radius: 24px; border: 1px solid var(--border); box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1); }
    }

    @media (max-width: 480px) {
        .quiz-banner { border-radius: 20px 20px 0 0; }
    }
</style>

<script is:inline>
    const audio = document.getElementById('mainAudio');
    const cards = document.querySelectorAll('.dialog-card');

    window.setPlaySpeed = function(rate, btn) {
        if (!audio) return;
        audio.playbackRate = rate;
        document.querySelectorAll('.btn-speed').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
    }

    cards.forEach(card => {
        card.addEventListener('click', () => {
            const time = parseFloat(card.getAttribute('data-time'));
            audio.currentTime = time;
            audio.play();
        });
    });

    let lastActive = -1;
    audio.addEventListener('timeupdate', () => {
        const now = audio.currentTime;
        let currentIdx = -1;
        cards.forEach((card, i) => {
            const start = parseFloat(card.getAttribute('data-time'));
            const next = cards[i + 1];
            const end = next ? parseFloat(next.getAttribute('data-time')) : Infinity;
            if (now >= start && now < end) currentIdx = i;
        });
        if (currentIdx !== -1 && currentIdx !== lastActive) {
            cards.forEach(c => c.classList.remove('active'));
            const activeCard = cards[currentIdx];
            activeCard.classList.add('active');
            activeCard.scrollIntoView({ behavior: 'smooth', block: 'center' });
            lastActive = currentIdx;
        }
    });
</script>

</body>
</html>